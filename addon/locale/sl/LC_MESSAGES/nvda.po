#. Translators: label of a dialog.
#: addon\installTasks.py:45
msgid "This add-on allows to confirm if you want to copy and cut, replacing the clipboard contents,\n"
"\t\twhen pressing control+c and control+x. This is named Emulate copy and cut.\n"
"\t\tDo you want to configure Emulate copy and cut now? You may do or change this later."
msgstr "Ta dodatek vam dovoljuje potrditi, če želite preslikati in izrezati, z zamenjavo vsebine odložišča,\n"
"\t\tko pritisnete control+c in control+x. To se imenuje Oponašanje preslikave in izreza.\n"
"\t\tŽelite nastaviti Oponašanje preslikave in izreza zdaj? To lahko storite ali spremenite tudi kasneje."

#. Translators: title of a dialog.
#: addon\installTasks.py:49
msgid "Configure Emulate copy and cut"
msgstr "Nastavi Oponašanje preslikave in izreza"

#. Translators: label of a dialog.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:35
msgid "Preformatted text in HTML"
msgstr "Predoblikovano besedilo v HTML"

#. Translators: label of a dialog.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:37
msgid "HTML as shown in a web browser"
msgstr "HTML, kot se prikaže v spletnem brskalniku"

#. Translators: Text of the clipboard shown without being formatted.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:40
msgid "Plain text"
msgstr "Golo besedilo"

#. Translators: message presented in input mode.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:128
msgid "Shows the Clip Contents Designer settings."
msgstr "Prikazuje nastavitve Clip Contents Designer."

#. Translators: message presented when the clipboard content has been deleted.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:138
msgid "Clipboard cleared"
msgstr "Odložišče počiščeno"

#. Translators: message presented when the clipboard content cannot be deleted.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:141
msgid "Clipboard not cleared"
msgstr "Odložišče ni počiščeno"

#. Translators: Label of a dialog.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:228
msgid "Please, confirm if you want to add text to the clipboard"
msgstr "Prosimo, potrdite, če želite dodati besedilo v odložišče"

#. Translators: Title of a dialog.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:230
msgid "Adding text to clipboard"
msgstr "Dodajanje besedila v odložišče"

#. Translators: message presented when the text has been added to the clipboard.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:236
#: addon\globalPlugins\clipContentsDesigner\__init__.py:245
msgid "Added"
msgstr "Dodano"

#. Translators: message presented when the text cannot be added to the clipboard.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:239
#: addon\globalPlugins\clipContentsDesigner\__init__.py:248
msgid "Cannot add"
msgstr "Ni mogoče dodati"

#. Translators: message presented in input mode.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:253
msgid "Retrieves the selected string or the text from the previously set start marker up to and including the current position of the review cursor, and adds it to the clipboard."
msgstr "Izbran niz ali vsebino od predhodno postavljene točke začetka do vključno trenutnega položaja pregledne utripalke obdela in doda v odložišče."

#. Translators: Label of a dialog.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:269
msgid "Please, confirm if you want to clear the clipboard"
msgstr "Prosimo, potrdite, če želite počistiti odložišče"

#. Translators: Title of a dialog.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:271
msgid "Clearing clipboard"
msgstr "Čiščenje odložišča"

#. Translators: message presented in input mode.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:280
msgid "Deletes the added text and the content of the clipboard."
msgstr "Izbriše tako dodano, kot osnovno vsebino odložišča."

#. Translators: Label of a dialog.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:308
msgid "Please, confirm if you want to copy to the clipboard"
msgstr "Prosimo, potrdite, če želite preslikati v odložišče"

#. Translators: Title of a dialog.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:310
msgid "Copying to clipboard"
msgstr "Preslikava v odložišče"

#. Translators: message presented in input mode.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:320
msgid "Copies to the clipboard, with the possibility of being asked for a previous confirmation"
msgstr "Preslika v odložišče z možnostjo zaprosila po predhodni odobritvi"

#. Translators: Label of a dialog.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:338
msgid "Please, confirm if you want to cut from the clipboard"
msgstr "Prosimo, potrdite, če želite izrezati iz odložišča"

#. Translators: Title of a dialog.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:340
msgid "Cutting from clipboard"
msgstr "Izrezovanje iz odložišča"

#. Translators: message presented in input mode.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:350
msgid "Cuts from the clipboard, with the possibility of being asked for a previous confirmation"
msgstr "Izreže iz odložišča z možnostjo zaprosila po predhodni odobritvi"

#. Translators: message presented in input mode.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:361
msgid "Shows the clipboard text as HTML in browse mode"
msgstr "Prikaže besedilo iz odložišča kot HTML v brskalniškem delovanju"

#. Translators: presented when clipboard is not empty, but there is no text to show in browse mode.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:371
#: addon\globalPlugins\clipContentsDesigner\__init__.py:412
msgid "Clipboard is not empty, but there is no text to show"
msgstr "Odložišče ni prazno, toda tam ni besedila za prikaz"

#. Translators: presented when clipboard is empty.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:374
#: addon\globalPlugins\clipContentsDesigner\__init__.py:415
msgid "Clipboard is empty"
msgstr "Odložišče je prazno"

#. Translators: title of a browseable message.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:390
#: addon\globalPlugins\clipContentsDesigner\__init__.py:426
#, python-brace-format
msgid "Clipboard text ({max}/{current} - {formatForTitle})"
msgstr "Besedilo v odložišču ({max}/{current} - {formatForTitle})"

#. Translators: message presented in input mode.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:402
msgid "Shows the clipboard textual contents as plain text in browse mode"
msgstr "Prikaže besedilno vsebino odložišča kot golo besedilo v brskalniškem delovanju"

#. Translators: label of a dialog.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:444
msgid "Type the string to be used as a &separator between contents added to the clipboard."
msgstr "Vnesi niz, ki bo &ločnica med besedilom, ki ga dodajate v odložišče."

#. Translators: label of a dialog.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:449
msgid "&Add text before clip data"
msgstr "&Dodaj besedilo pred izrezkom podatkov"

#. Translators: label of a dialog.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:452
msgid "Sele&ct the actions which require previous confirmation"
msgstr "I&zberi dejanja, ki potrebujejo predhodno odobritev"

#. Translators: label of a dialog.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:455
msgid "Confirm to add text"
msgstr "Potrdi dodajanje besedila"

#. Translators: label of a dialog.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:457
msgid "Confirm to clear clipboard"
msgstr "Potrdi čiščenje odložišča"

#. Translators: label of a dialog.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:459
msgid "Confirm to emulate copy"
msgstr "Potrdi oponašanje preslikave"

#. Translators: label of a dialog.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:461
msgid "Confirm to emulate cut"
msgstr "Potrdi oponašanje izreza"

#. Translators: label of a dialog.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:480
msgid "&Request confirmation before performing the selected actions when:"
msgstr "&Zahtevaj potrditev pred izvedbo izbranih dejanj, ko:"

#. Translators: label of a dialog.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:483
msgid "Always"
msgstr "Vedno"

#. Translators: label of a dialog.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:485
msgid "If the clipboard contains text"
msgstr "Če odložišče vsebuje besedilo"

#. Translators: label of a dialog.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:487
msgid "If the clipboard is not empty"
msgstr "Če odložišče ni prazno"

#. Translators: label of a dialog.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:498
msgid "&Format to show the clipboard text as HTML in browse mode:"
msgstr "&Oblika za prikaz besedila v odložišču kot HTML v brskalniškem delovanju:"

#. Translators: label of a dialog.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:502
msgid "&Maximum number of characters when showing clipboard text in browse mode"
msgstr "&Največje število znakov, ko se prikazuje besedilo iz odložišča v brskalniškem delovanju"

#. Translators: label of a dialog.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:512
msgid "Show configuration dialog when &updating"
msgstr ""

#. Translators: label of a dialog.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:516
msgid "Restore defaults"
msgstr ""

#. Add-on summary/title, usually the user visible name of the add-on
#. Translators: Summary/title for this add-on
#. to be shown on installation and add-on information found in add-on store
#: buildVars.py:21
msgid "Clip Contents Designer"
msgstr "Clip Contents Designer"

#. Add-on description
#. Translators: Long description to be shown for this add-on on add-on information from add-on store
#: buildVars.py:24
msgid "Allows the joining of separate fragments of text on the clipboard and clearing of clipboard content. Current text on the clipboard can be presented in browse mode. Option to request confirmation before performing actions such as copy, cut, add text, or clearing the clipboard to avoid accidental changes."
msgstr ""

#. Brief changelog for this version
#. Translators: what's new content for the add-on version to be shown in the add-on store
#: buildVars.py:29
msgid "* Compatible with NVDA 2026.1."
msgstr ""

