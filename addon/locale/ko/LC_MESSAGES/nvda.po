#. Translators: label of a dialog.
#: addon\installTasks.py:42
msgid "This add-on allows to confirm if you want to copy and cut, replacing the clipboard contents,\n"
"\t\twhen pressing control+c and control+x. This is named Emulate copy and cut.\n"
"\t\tDo you want to configure Emulate copy and cut now? You may do or change this later."
msgstr "이 추가기능은 사용자가 컨트롤+C 혹은 컨트롤+X를 눌러서 복사하기나 잘라내기 기능으로 클립보드의\n"
"\t\t내용을 덮어쓸 때 확인을 해줍니다. 이는 모방한 복사하기/잘라내기라고 이름 붙여졌으며, 기본 설정상\n"
"\t\t클립보드가 텍스트를 보관하고 있을 때만 동작합니다. 지금 모방한 복사하기/잘라내기에 대한 설정을\n"
"\t\t시작하시겠습니까? 나중에 설정할 수도 있습니다."

#. Translators: title of a dialog.
#: addon\installTasks.py:46
msgid "Configure Emulate copy and cut"
msgstr "복사 및 잘라내기 모방 기능 설정"

#. Translators: label of a dialog.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:34
msgid "Preformatted text in HTML"
msgstr "HTML 형식의 텍스트"

#. Translators: label of a dialog.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:36
msgid "HTML as shown in a web browser"
msgstr "웹브라우저에서 표현되는 HTML"

#. Translators: Text of the clipboard shown without being formatted.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:39
msgid "Plain text"
msgstr "일반 텍스트"

#. Translators: message presented in input mode.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:121
msgid "Shows the Clip Contents Designer settings."
msgstr "Clip Contents Designer 설정을 보여줍니다."

#. Translators: message presented when the clipboard content has been deleted.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:131
msgid "Clipboard cleared"
msgstr "클립보드 텍스트 삭제됨"

#. Translators: message presented when the clipboard content cannot be deleted.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:134
msgid "Clipboard not cleared"
msgstr "클립보드 텍스트 삭제 실패"

#. Translators: message presented when it's not possible to add text, since no text has been selected.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:175
msgid "No text to add"
msgstr ""

#. Translators: Label of a dialog.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:217
msgid "Please, confirm if you want to add text to the clipboard"
msgstr "클립보드에 텍스트 추가하려면 확인하세요"

#. Translators: Title of a dialog.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:219
msgid "Adding text to clipboard"
msgstr "클립보드에 텍스트 추가 설정"

#. Translators: message presented when the text has been added to the clipboard.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:224
#: addon\globalPlugins\clipContentsDesigner\__init__.py:233
msgid "Added"
msgstr "추가"

#. Translators: message presented when the text cannot be added to the clipboard.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:227
#: addon\globalPlugins\clipContentsDesigner\__init__.py:236
msgid "Cannot add"
msgstr "추가 불가"

#. Translators: message presented in input mode.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:241
msgid "Retrieves the selected string or the text from the previously set start marker up to and including the current position of the review cursor, and adds it to the clipboard."
msgstr "Retrieves the selected string or the text from the previously set start marker up to and including the current position of the review cursor, and adds it to the clipboard."

#. Translators: Label of a dialog.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:258
msgid "Please, confirm if you want to clear the clipboard"
msgstr "클립보드를 초기화하려면 확인하세요"

#. Translators: Title of a dialog.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:260
msgid "Clearing clipboard"
msgstr "클립보드 초기화"

#. Translators: message presented in input mode.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:268
msgid "Deletes the added text and the content of the clipboard."
msgstr "추가된 문구와 클립보드에 포함된 내용을 삭제합니다."

#. Translators: Label of a dialog.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:293
msgid "Please, confirm if you want to copy to the clipboard"
msgstr "클립보드에 복사하려면 확인하세요"

#. Translators: Title of a dialog.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:295
msgid "Copying to clipboard"
msgstr "클립보드에 복사"

#. Translators: message presented in input mode.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:306
msgid "Copies to the clipboard, with the possibility of being asked for a previous confirmation"
msgstr "클립보드로 내용을 복사하며, 사용자의 확인을 요구할 수 있습니다."

#. Translators: Label of a dialog.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:324
msgid "Please, confirm if you want to cut from the clipboard"
msgstr "클립보드에서 자르려면 확인하세요"

#. Translators: Title of a dialog.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:326
msgid "Cutting from clipboard"
msgstr "클립보드에서 자르기"

#. Translators: message presented in input mode.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:334
msgid "Cuts from the clipboard, with the possibility of being asked for a previous confirmation"
msgstr "클립보드에서 내용을 잘라내며, 사용자의 확인을 요구할 수 있습니다."

#. Translators: message presented in input mode.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:347
msgid "Shows the clipboard text as HTML in browse mode"
msgstr "브라우즈 모드에서 클립보드에 들어있는 문구를 HTML로 표시합니다."

#. Translators: presented when clipboard is not empty, but there is no text to show in browse mode.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:357
#: addon\globalPlugins\clipContentsDesigner\__init__.py:393
msgid "Clipboard is not empty, but there is no text to show"
msgstr "클립보드가 비어있지는 않지만, 표시할 문구가 없습니다."

#. Translators: presented when clipboard is empty.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:360
#: addon\globalPlugins\clipContentsDesigner\__init__.py:396
msgid "Clipboard is empty"
msgstr "클립보드가 비어 있습니다"

#. Translators: title of a browseable message.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:377
#: addon\globalPlugins\clipContentsDesigner\__init__.py:408
#, python-brace-format
msgid "Clipboard text ({max}/{current} - {formatForTitle})"
msgstr "클립보드 문구 ({max}/{current} - {formatForTitle})"

#. Translators: message presented in input mode.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:383
msgid "Shows the clipboard textual contents as plain text in browse mode"
msgstr "브라우저 모드에서 클립보드에 저장된 내용을 일반 문자로 표시"

#. Translators: label of a dialog.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:420
msgid "Type the string to be used as a &separator between contents added to the clipboard."
msgstr "클립보드에 추가되는 텍스트를 구분하기 위한 문자열 입력(&S)"

#. Translators: label of a dialog.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:427
msgid "&Add text before clip data"
msgstr "클립 데이터 앞에 문자 추가(&A)"

#. Translators: label of a dialog.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:430
msgid "Sele&ct the actions which require previous confirmation"
msgstr "수행 전에 확인이 필요한 기능들을 선택하세요"

#. Translators: label of a dialog.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:433
msgid "Confirm to add text"
msgstr "문자를 추가하려면 확인하세요"

#. Translators: label of a dialog.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:435
msgid "Confirm to clear clipboard"
msgstr "클립보드를 비우려면 확인하세요"

#. Translators: label of a dialog.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:437
msgid "Confirm to emulate copy"
msgstr "복사 기능을 모방하려면 확인하세요"

#. Translators: label of a dialog.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:439
msgid "Confirm to emulate cut"
msgstr "잘라내기 기능을 모방하려면 확인하세요"

#. Translators: label of a dialog.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:456
msgid "&Request confirmation before performing the selected actions when:"
msgstr "아래 선택된 기능을 수행하기 전에 먼저 확인합니다. (&R)"

#. Translators: label of a dialog.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:459
msgid "Always"
msgstr "언제나"

#. Translators: label of a dialog.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:461
msgid "If the clipboard contains text"
msgstr "클립보드가 문자를 포함하고 있는 경우"

#. Translators: label of a dialog.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:463
msgid "If the clipboard is not empty"
msgstr "클립보드가 비어있지 않은 경우"

#. Translators: label of a dialog.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:470
msgid "&Format to show the clipboard text as HTML in browse mode:"
msgstr "브라우즈 모드에서 클립보드에 저장된 내용을 HTML 형식으로 표시(&F)"

#. Translators: label of a dialog.
#: addon\globalPlugins\clipContentsDesigner\__init__.py:474
msgid "&Maximum number of characters when showing clipboard text in browse mode"
msgstr "브라우즈 모드에서 클립보드에 저장된 문구를 표시할 때 최대 표시 글자수(&M)"

#. Add-on summary, usually the user visible name of the addon.
#. Translators: Summary for this add-on to be shown on installation and add-on information.
#: buildVars.py:17
msgid "Clip Contents Designer"
msgstr "Clip Contents Designer"

#. Add-on description
#. Translators: Long description to be shown for this add-on on add-on information from add-ons manager
#: buildVars.py:20
msgid "Add-on for managing clipboard text."
msgstr ""

